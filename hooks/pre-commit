#!/bin/bash
set -euo pipefail

# Pre-commit hook: if any plugin.json and marketplace.json are both staged,
# their versions must match. Supports multiple plugins.

MARKETPLACE_JSON=".claude-plugin/marketplace.json"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only)

MARKETPLACE_STAGED=$(echo "$STAGED_FILES" | grep "^${MARKETPLACE_JSON}$" || true)

# Find all staged plugin.json files
STAGED_PLUGIN_JSONS=$(echo "$STAGED_FILES" | grep 'plugins/.*/\.claude-plugin/plugin\.json$' || true)

# If nothing version-related is staged, nothing to check
if [ -z "$STAGED_PLUGIN_JSONS" ] && [ -z "$MARKETPLACE_STAGED" ]; then
    exit 0
fi

# If plugin.json(s) staged but not marketplace, warn
if [ -n "$STAGED_PLUGIN_JSONS" ] && [ -z "$MARKETPLACE_STAGED" ]; then
    echo "ERROR: Plugin version file(s) staged without marketplace.json!"
    echo ""
    echo "  Staged plugin.json files:"
    echo "$STAGED_PLUGIN_JSONS" | sed 's/^/    /'
    echo "  Missing: ${MARKETPLACE_JSON}"
    echo ""
    echo "Stage both version files or unstage the one you changed."
    exit 1
fi

# If marketplace staged but no plugin.json, warn
if [ -z "$STAGED_PLUGIN_JSONS" ] && [ -n "$MARKETPLACE_STAGED" ]; then
    echo "ERROR: marketplace.json staged without any plugin.json!"
    echo ""
    echo "  Staged:  ${MARKETPLACE_JSON}"
    echo "  Missing: plugins/*/.claude-plugin/plugin.json"
    echo ""
    echo "Stage both version files or unstage the one you changed."
    exit 1
fi

# Both staged — check each plugin version matches its marketplace entry
ERRORS=0
while IFS= read -r PLUGIN_JSON; do
    PLUGIN_NAME=$(git show :"${PLUGIN_JSON}" | python3 -c "import sys,json; print(json.load(sys.stdin)['name'])")
    PLUGIN_VER=$(git show :"${PLUGIN_JSON}" | python3 -c "import sys,json; print(json.load(sys.stdin)['version'])")

    MARKETPLACE_VER=$(git show :"${MARKETPLACE_JSON}" | python3 -c "
import sys, json
data = json.load(sys.stdin)
plugins = [p for p in data['plugins'] if p['name'] == '${PLUGIN_NAME}']
print(plugins[0]['version'] if plugins else 'NOT_FOUND')
")

    if [ "$PLUGIN_VER" != "$MARKETPLACE_VER" ]; then
        echo "ERROR: Version mismatch for '${PLUGIN_NAME}'!"
        echo "  plugin.json:      ${PLUGIN_VER}"
        echo "  marketplace.json: ${MARKETPLACE_VER}"
        ERRORS=$((ERRORS + 1))
    else
        echo "Version check passed for '${PLUGIN_NAME}': ${PLUGIN_VER}"
    fi
done <<< "$STAGED_PLUGIN_JSONS"

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "Fix version mismatches before committing."
    exit 1
fi
