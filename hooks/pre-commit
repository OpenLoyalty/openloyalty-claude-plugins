#!/bin/bash
set -euo pipefail

# Pre-commit hook: if both version files are staged, their versions must match.
# Does NOT require a version bump on every plugin commit — releases are done on-demand.

PLUGIN_JSON="plugins/openloyalty/.claude-plugin/plugin.json"
MARKETPLACE_JSON=".claude-plugin/marketplace.json"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only)

PLUGIN_JSON_STAGED=$(echo "$STAGED_FILES" | grep "^${PLUGIN_JSON}$" || true)
MARKETPLACE_STAGED=$(echo "$STAGED_FILES" | grep "^${MARKETPLACE_JSON}$" || true)

# If neither version file is staged, nothing to check
if [ -z "$PLUGIN_JSON_STAGED" ] && [ -z "$MARKETPLACE_STAGED" ]; then
    exit 0
fi

# If only one is staged, warn
if [ -z "$PLUGIN_JSON_STAGED" ] || [ -z "$MARKETPLACE_STAGED" ]; then
    echo "ERROR: Only one version file is staged — both must be updated together!"
    echo ""
    if [ -z "$PLUGIN_JSON_STAGED" ]; then
        echo "  Missing: ${PLUGIN_JSON}"
        echo "  Staged:  ${MARKETPLACE_JSON}"
    else
        echo "  Staged:  ${PLUGIN_JSON}"
        echo "  Missing: ${MARKETPLACE_JSON}"
    fi
    echo ""
    echo "Stage both version files or unstage the one you changed."
    exit 1
fi

# Both staged — check versions are in sync
PLUGIN_VER=$(git show :"${PLUGIN_JSON}" | python3 -c "import sys,json; print(json.load(sys.stdin)['version'])")

MARKETPLACE_VER=$(git show :"${MARKETPLACE_JSON}" | python3 -c "
import sys, json
data = json.load(sys.stdin)
plugins = [p for p in data['plugins'] if p['name'] == 'openloyalty']
print(plugins[0]['version'] if plugins else 'NOT_FOUND')
")

if [ "$PLUGIN_VER" != "$MARKETPLACE_VER" ]; then
    echo "ERROR: Version mismatch!"
    echo ""
    echo "  plugin.json:      ${PLUGIN_VER}"
    echo "  marketplace.json: ${MARKETPLACE_VER}"
    echo ""
    echo "Both must have the same version."
    exit 1
fi

echo "Version check passed: ${PLUGIN_VER}"
